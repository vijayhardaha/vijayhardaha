// =======================================================================
// Typescript Configuration
// =======================================================================
// Purpose: Static type-checking and module resolution strategy for the
//          repository, ensuring predictable behavior and strong typing
//          across code.
// Docs: https://www.typescriptlang.org/tsconfig
// =======================================================================

{
  "compilerOptions": {
    // ---- Target & libs ----
    // Use modern ECMAScript features supported by current runtimes
    "target": "ES2024",

    // Include DOM types and iterable helpers for browser-based code
    "lib": ["dom", "dom.iterable"],

    // Use the modern React JSX transform
    "jsx": "react-jsx",

    // ---- Module resolution ----
    // Use native ESM module syntax and Node-style resolution
    "module": "esnext",
    "moduleResolution": "node",

    // Base directory for non-relative imports used by tooling
    "baseUrl": ".",

    // Map `@/*` to `./src/*` for cleaner absolute imports
    "paths": { "@/*": ["./src/*"] },

    // Allow importing JSON files as modules
    "resolveJsonModule": true,

    // Allow default interop for CommonJS modules when consuming CJS packages
    "esModuleInterop": true,

    // ---- Compilation strategy ----
    // Speed up consecutive builds by enabling incremental compilation caching
    "incremental": true,

    // Do not emit JS during type-checking; Next.js handles build output
    "noEmit": true,

    // Required for tools like swc/esbuild used in Next.js
    "isolatedModules": true,

    // Allow mixed JS/TS code during gradual migration
    "allowJs": true,

    // ---- Type safety ----
    // Enable all strict type-checking options for safer code
    "strict": true,

    // Skip deep type checks inside node_modules for performance
    "skipLibCheck": true,

    // Avoid case-sensitivity issues across filesystems
    "forceConsistentCasingInFileNames": true,

    // ---- Plugins & extras ----
    "plugins": [{ "name": "next" }],
    "downlevelIteration": true
  },

  // ---- Includes ----
  // Files to include in the project type-checking scope
  "include": [
    ".next/dev/types/**/*.ts",
    ".next/types/**/*.ts",
    "*.config.mjs",
    "*.d.ts",
    "**/*.{js,jsx,ts,tsx,mjs,cjs}",
    "next-env.d.ts"
  ],

  // ---- Excludes ----
  "exclude": ["node_modules"]
}
