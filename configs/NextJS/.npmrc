# ======================================================================
# pnpm Configuration
# ======================================================================
# Purpose: Enforce dependency resolution & compatibility rules for pnpm.
# Docs: https://pnpm.io/npmrc
# ======================================================================

# ---- Dependency strategy ----
# Prefer explicit peer dependency behavior and control over the
# dependency graph
strict-peer-dependencies=true
ignore-peer-dependencies=false
auto-install-peers=false
save-exact=false

# ---- Compatibility (pnpm v10+) ----
# Workaround for VS Code ESLint plugin compatibility with pnpm's
# node_modules layout
# See: https://github.com/microsoft/vscode-eslint/issues/1986
public-hoist-pattern[]=*eslint-plugin*
